# ── AutoSplit Frontend — Environment Variables ─────────────────────────────────
#
# Copy this file to .env.local for local development.
# Never commit .env.local to git.
#
# In production (Vercel), set these in the Vercel dashboard under
# Project Settings → Environment Variables.

# ── Backend API URL ────────────────────────────────────────────────────────────
# LOCAL: Leave blank — Vite's dev proxy handles /api → localhost:8001
# PRODUCTION: Set to your Railway backend URL
#
# Example: VITE_API_BASE=https://autosplit-backend.up.railway.app
# The /api prefix is added automatically by client.js — don't include it here.
VITE_API_BASE=
