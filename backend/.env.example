# ── AutoSplit Backend Environment Variables ───────────────────────────────────
# Copy this file to .env and fill in your real values.
# NEVER commit .env to git — it contains secrets.

# ── Supabase (required for cloud mode) ───────────────────────────────────────
# Your PostgreSQL connection string from Supabase → Settings → Database → URI
# Replace [YOUR-PASSWORD] with the password you set when creating the project.
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres

# Found in Supabase → Settings → API → JWT Settings → JWT Secret
SUPABASE_JWT_SECRET=your-supabase-jwt-secret-here

# ── Frontend URL (for CORS in production) ─────────────────────────────────────
# Set this to your Vercel deployment URL after you deploy.
# Leave blank for local development.
FRONTEND_URL=

# ── Stripe (Phase 3 — leave blank until you set up payments) ─────────────────
# Found in Stripe Dashboard → Developers → API Keys
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# Price IDs from your Stripe products/prices
STRIPE_PER_TRIP_PRICE_ID=
STRIPE_MONTHLY_PRICE_ID=
