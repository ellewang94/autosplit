# ── AutoSplit Backend — Environment Variables ──────────────────────────────────
#
# Copy this file to .env for local development. Never commit .env to git.
#
# In production (Railway), you set these as "Variables" in the Railway dashboard.
# Railway injects them into the container automatically — no .env file needed there.

# ── Database ───────────────────────────────────────────────────────────────────
# LOCAL (SQLite): Leave blank — backend/database.py auto-uses autosplit.db
# PRODUCTION (Supabase PostgreSQL): Set this to your Supabase connection string
#
# Format: postgresql://[user]:[password]@[host]:[port]/[database]
# Get it from: Supabase Dashboard → Project Settings → Database → Connection string → URI
# IMPORTANT: Use the "Transaction" pooler URL (port 6543), NOT the direct connection URL.
#            The direct URL (port 5432) has a 10-connection limit that's easy to hit.
DATABASE_URL=

# ── CORS (frontend URL) ────────────────────────────────────────────────────────
# This tells the backend which frontend URL is allowed to call it.
# LOCAL: Not needed — localhost:5173 is already whitelisted in main.py
# PRODUCTION: Set to your Vercel frontend URL (e.g. https://autosplit.vercel.app)
FRONTEND_URL=
